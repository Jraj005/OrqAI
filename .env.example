# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL — local example (adjust port/credentials to match your setup)
DATABASE_URL=postgresql://postgres:password@localhost:5433/OrqAI

# Redis — Docker example (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# Server
NODE_ENV=development
PORT=3000

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
